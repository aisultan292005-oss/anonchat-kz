# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin Telegram user IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/anonbot

# ── Payments ──────────────────────────────────────────────────────────────────
# For Telegram Stars leave empty string; for real payments use provider token
PAYMENT_PROVIDER_TOKEN=
PREMIUM_PRICE_XTR=100
PREMIUM_DAYS=30

# ── Settings ──────────────────────────────────────────────────────────────────
INACTIVITY_TIMEOUT=300
LOG_LEVEL=INFO
LOG_FILE=bot.log
